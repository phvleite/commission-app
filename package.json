{
  "name": "commission-app",
  "version": "1.0.0",
  "description": "Commission App - Electron + React",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:electron\" \"npm:dev:renderer\"",
    "dev:electron": "cd electron && electron .",
    "dev:renderer": "cd renderer && vite",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.commission.app",
    "productName": "Commission App",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^24.6.0"
  }
}
