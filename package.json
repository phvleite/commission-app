{
    "name": "commission-app",
    "version": "1.0.1",
    "description": "Commission App - Electron + React",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
        "dev:renderer": "npm --prefix renderer run dev",
        "dev:electron": "npx electron electron/main.js",
        "build:renderer": "npm --prefix renderer run build",
        "build": "npm run build:renderer",
        "dist": "npm run build && electron-builder",
        "electron": "npx electron electron/main.js",
        "test": "jest --watchAll",
        "test:ci": "jest"
    },
    "build": {
        "appId": "com.commission.app",
        "productName": "Commission App",
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron/**/*",
            "renderer/dist/**/*",
            "package.json",
            "node_modules/sql.js/**/*"
        ],
        "extraResources": [
            {
                "from": "node_modules/sql.js/dist/sql-wasm.wasm",
                "to": "sql-wasm.wasm"
            },
            {
                "from": "node_modules/sql.js/dist/sql-wasm.js",
                "to": "sql-wasm.js"
            }
        ],
        "win": {
            "target": "nsis"
        }
    },
    "dependencies": {
        "concurrently": "^8.2.2",
        "sql.js": "1.10.2"
    },
    "devDependencies": {
        "electron": "28.2.0",
        "electron-builder": "24.6.0",
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "babel-jest": "^29.7.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1"
    }
}
