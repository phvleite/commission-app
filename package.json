{
  "name": "commission-app",
  "version": "1.0.0",
  "description": "Commission App - Electron + React",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:electron\" \"npm:dev:renderer\"",
    "dev:electron": "cd electron && electron .",
    "dev:renderer": "cd renderer && vite",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "test": "jest --watchAll",
    "test:ci": "jest"
  },
  "build": {
    "appId": "com.commission.app",
    "productName": "Commission App",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^29.7.0",
    "electron": "^43.0.0",
    "electron-builder": "^24.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  }
}
